# ─── Sprint Tracker — Environment Variables ───────────────────────────────
#
# Copy this file to .env and fill in your values.
# .env is in .gitignore and will never be committed.

# OpenAI API key — required for AI-generated sprint plans.
# Get yours at https://platform.openai.com/api-keys
# Leave blank to fall back to the built-in rule-based plan generator.
VITE_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
